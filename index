function getEffectiveMod() {
  const m = state.mods;
  const leMod = [0,3,6,9][m.LE]||0;
  const auMod = [0,3,6][m.AU]||0;
  const beMod = Math.max(0, m.BE-2);
  return m.MR + leMod + auMod + m.aufrecht*3 + beMod + m.wiederholung*3 + m.freeMod;
}

function calcResults(E1,E2,E3,ZfW,modifier) {
  let succ=0, fumb=0, crit=0;
  const dist = {};
  for (let d1=1;d1<=20;d1++) for (let d2=1;d2<=20;d2++) for (let d3=1;d3<=20;d3++) {
    const nT=(d1===20?1:0)+(d2===20?1:0)+(d3===20?1:0);
    const nO=(d1===1?1:0)+(d2===1?1:0)+(d3===1?1:0);
    if (nT>=2){fumb++;continue}
    const pool=ZfW-modifier;
    if (nO>=2){
      crit++;succ++;
      const zs=Math.max(1,pool>0?pool:1);
      dist[zs]=(dist[zs]||0)+1;
      continue;
    }
    let rem;
    if (pool>=0){
      const ex=Math.max(0,d1-E1)+Math.max(0,d2-E2)+Math.max(0,d3-E3);
      rem=pool-ex;
    } else {
      const ex=Math.max(0,d1-(E1+pool))+Math.max(0,d2-(E2+pool))+Math.max(0,d3-(E3+pool));
      rem=-ex;
    }
    if (rem>=0){
      succ++;
      const zs=Math.max(1,rem);
      dist[zs]=(dist[zs]||0)+1;
    }
  }
  const total=8000;
  let expZfp=0, succCount=0;
  Object.entries(dist).forEach(([k,v])=>{expZfp+=parseInt(k)*v;succCount+=v;});
  return {
    successRate:succ/total,
    fumbleRate:fumb/total,
    criticalRate:crit/total,
    dist,
    expectedZfp: succCount>0?expZfp/succCount:0,
    succCount
  };
}

