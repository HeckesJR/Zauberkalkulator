function getResults() {
  const spell = state.spell;
  if (!spell) return null;
  const probe = [spell[1],spell[2],spell[3]];
  const E = probe.map(a => a==="—"?state.props[state.attrOverride]||10:state.props[a]||10);
  const mod = getEffectiveMod();
  return calcResults(E[0],E[1],E[2],state.ZfW,mod);
}

function render() {
  const app = document.getElementById("zkapp");
  const filtered = SPELLS.filter(s=>s[0].toLowerCase().includes(state.search.toLowerCase()));
  const mod = getEffectiveMod();
  const res = getResults();
  const probe = getProbe();
  const pool = state.ZfW - mod;

  let html = `
<h2 class="zk-title">DSA 4.1 — Zauberkalkulator</h2>
<p class="zk-subtitle">Alle ${SPELLS.length} Zauber aus dem Liber Cantiones · Exakte Probenberechnung (8.000 Kombinationen)</p>
<div class="zk-grid">

<div class="zk-card">
  <p class="zk-section">1 — Zauber wählen</p>
  <div class="zk-search-wrap">
    <input id="spell-search" type="text" placeholder="Zauber suchen…" value="${state.search}" style="width:100%;margin-bottom:0"
      oninput="state.search=this.value;state.showDD=true;render()"
      onfocus="state.showDD=true;render()"
      onblur="setTimeout(()=>{state.showDD=false;render()},180)">
    ${state.showDD && filtered.length>0?`
    <div class="zk-dropdown">${filtered.slice(0,80).map(s=>`
      <div class="zk-dd-item ${state.spell&&state.spell[0]===s[0]?'sel':''}"
        onmousedown="state.spell=s;state.search=s[0];state.showDD=false;render()">
        <span>${s[0]}</span>
        <span style="display:flex;gap:4px;align-items:center">
          <span class="zk-dd-probe">${s[1]}/${s[2]}/${s[3]}</span>
          ${s[5]?'<span style="font-size:10px;color:#854F0B">+MR</span>':''}
          <span class="zk-comp-badge" style="color:${COMP_COLORS[s[4]]}">${s[4]}</span>
        </span>
      </div>`).join("")}
    </div>`:``}
  </div>
  ${state.spell?`
  <div class="zk-probe-display">
    ${probe.map(a=>`<span class="zk-attr-badge">${a}</span>`).join('<span class="zk-slash">/</span>')}
    ${state.spell[5]?`<span class="zk-mr-badge">+MR</span>`:''}
    <span style="margin-left:4px;font-size:12px;color:var(--color-text-secondary)">Kompl. ${state.spell[4]}</span>
  </div>
  ${state.spell[1]==="—"||state.spell[2]==="—"||state.spell[3]==="—"?`
  <div style="margin-top:6px"><label class="zk-label">Variable Eigenschaft</label>
  <select onchange="state.attrOverride=this.value;render()">
    ${PROPS.map(p=>`<option value="${p}" ${state.attrOverride===p?'selected':''}>${p} (${state.props[p]})</option>`).join('')}
  </select></div>`:''}
  `:`<p style="font-size:13px;color:var(--color-text-tertiary);margin-top:8px">— noch kein Zauber gewählt —</p>`}
  
  <div class="zk-sep"></div>
  <div style="display:flex;gap:10px;align-items:flex-end">
    <div style="flex:1"><label class="zk-label">ZfW (Zauberfertigkeitswert)</label>
    <input type="number" id="zfw" min="0" max="30" value="${state.ZfW}" style="width:100%;font-size:16px;font-weight:500;text-align:center"
      oninput="state.ZfW=Math.max(0,Math.min(30,parseInt(this.value)||0));render()"></div>
    <div style="font-size:12px;color:var(--color-text-secondary);padding-bottom:8px">max ZfP*: <strong>${Math.max(0,pool)}</strong></div>
  </div>
</div>

<div class="zk-card">
  <p class="zk-section">2 — Held</p>
  <div class="zk-presets">
    ${Object.keys(PRESETS).map(n=>`
    <button class="zk-preset-btn ${state.preset===n?'active':''}"
      onclick="state.props={...PRESETS['${n}']};state.preset='${n}';render()">
      ${n}</button>`).join("")}
    <button class="zk-preset-btn ${state.preset===null?'active':''}"
      onclick="state.preset=null;render()">Eigener</button>
  </div>
  <div class="zk-props">
    ${PROPS.map(p=>`
    <div class="zk-prop">
      <label title="${PROP_NAMES[p]}">${p}</label>
      <input type="number" min="1" max="21" value="${state.props[p]||10}"
        style="${probe&&probe.includes(p)?'border-color:var(--color-border-info);background:var(--color-background-info)':''}"
        oninput="state.props['${p}']=Math.max(1,Math.min(21,parseInt(this.value)||10));state.preset=null;render()">
    </div>`).join("")}
  </div>
  ${probe?`<p style="font-size:11px;color:var(--color-text-tertiary);margin-top:6px">Hervorgehobene Felder: für aktuelle Probe relevante Eigenschaften</p>`:''}
</div>

<div class="zk-card">
  <p class="zk-section">3 — Repräsentation</p>
  <div class="zk-rep-btns">
    ${["Mag","Elf","Dru","Geo","Hex","Sch"].map(r=>`
    <button class="zk-rep-btn ${state.rep===r?'active':''}" onclick="state.rep='${r}';render()">${r}</button>`).join("")}
  </div>
  ${state.rep==="Mag"?`<p style="font-size:12px;color:var(--color-text-secondary);margin-top:8px">Gildenmagie: Spontane Modifikations-Zuschläge werden halbiert · Verlängerungsbonus +1</p>`:''}
  ${state.rep==="Elf"?`<p style="font-size:12px;color:var(--color-text-secondary);margin-top:8px">Elfisch: Doppelte Wirkungsdauer gratis · augenblicklich/permanent: –1 AsP · Wiederholung: +5 statt +3</p>`:''}
  ${state.rep==="Dru"||state.rep==="Geo"?`<p style="font-size:12px;color:var(--color-text-secondary);margin-top:8px">Kein Kontakt mit verhüttetem Metall als Voraussetzung</p>`:''}
  ${state.rep==="Hex"?`<p style="font-size:12px;color:var(--color-text-secondary);margin-top:8px">Hexe: Misslingen kostet nur 1/3 der AsP · Stimmungsbonus möglich (±3 ZfP*)</p>`:''}
  ${state.rep==="Sch"?`<p style="font-size:12px;color:var(--color-text-secondary);margin-top:8px">Schelme: MR bis 3 ignorierbar · Kosten auf 2/3 reduziert</p>`:''}
</div>

<div class="zk-card">
  <p class="zk-section">4 — Erschwernisse</p>
  <div class="zk-mods">
    <div class="zk-mod">
      <label>Magieresistenz (MR) des Opfers</label>
      <input type="number" min="0" max="30" value="${state.mods.MR}"
        oninput="state.mods.MR=Math.max(0,parseInt(this.value)||0);render()">
    </div>
    <div class="zk-mod">
      <label>Aufrechterhaltene Zauber</label>
      <input type="number" min="0" max="5" value="${state.mods.aufrecht}"
        oninput="state.mods.aufrecht=Math.max(0,parseInt(this.value)||0);render()">
    </div>
    <div class="zk-mod">
      <label>Niedrige LeP (0=normal, 1=½, 2=⅓, 3=¼)</label>
      <select onchange="state.mods.LE=parseInt(this.value);render()">
        ${[0,1,2,3].map(i=>`<option value="${i}" ${state.mods.LE===i?'selected':''}>${["Normal","Hälfte (+3)","Drittel (+6)","Viertel (+9)"][i]}</option>`).join('')}
      </select>
    </div>
    <div class="zk-mod">
      <label>Niedrige AuP (0=normal, 1=⅓, 2=¼)</label>
      <select onchange="state.mods.AU=parseInt(this.value);render()">
        ${[0,1,2].map(i=>`<option value="${i}" ${state.mods.AU===i?'selected':''}>${["Normal","Drittel (+3)","Viertel (+6)"][i]}</option>`).join('')}
      </select>
    </div>
    <div class="zk-mod">
      <label>Behinderung (BE-Wert)</label>
      <input type="number" min="0" max="8" value="${state.mods.BE}"
        oninput="state.mods.BE=Math.max(0,parseInt(this.value)||0);render()">
    </div>
    <div class="zk-mod">
      <label>Wiederholungsversuche (×3)</label>
      <input type="number" min="0" max="5" value="${state.mods.wiederholung}"
        oninput="state.mods.wiederholung=Math.max(0,parseInt(this.value)||0);render()">
    </div>
    <div class="zk-mod">
      <label>Weitere Erschwernis / Erleichterung</label>
      <input type="number" min="-20" max="30" value="${state.mods.freeMod}"
        oninput="state.mods.freeMod=parseInt(this.value)||0;render()">
    </div>
  </div>
  ${mod>0?`<p class="zk-modsum">Gesamt-Erschwernis: <span>+${mod}</span> · effektive ZfP: <span style="color:${pool<0?'var(--color-text-danger)':'var(--color-text-primary)'}">${pool}</span></p>`:''}
  ${pool<0?`<p class="zk-warn">Effektiver ZfP-Wert negativ (${pool}): Dieser Wert wirkt als zusätzliche Erschwernis auf alle drei Teilproben</p>`:''}
</div>

<div class="zk-card zk-card-full">
  <p class="zk-section">Ergebnis</p>
  ${!res?`<p class="zk-empty">Bitte zuerst einen Zauber auswählen und ZfW eingeben</p>`:`
  <div style="display:flex;gap:20px;align-items:flex-start;flex-wrap:wrap">
    <div>
      <svg class="zk-success-ring" width="100" height="100" viewBox="0 0 100 100" role="img" aria-label="Erfolgswahrscheinlichkeit">
        <circle cx="50" cy="50" r="40" fill="none" stroke="var(--color-border-tertiary)" stroke-width="10"/>
        <circle cx="50" cy="50" r="40" fill="none"
          stroke="${res.successRate>=0.7?'#3B6D11':res.successRate>=0.4?'#854F0B':'#A32D2D'}"
          stroke-width="10"
          stroke-dasharray="${(res.successRate*251.2).toFixed(1)} 251.2"
          stroke-linecap="round"/>
      </svg>
      <div style="text-align:center;margin-top:4px">
        <div style="font-size:18px;font-weight:500">${(res.successRate*100).toFixed(1)}%</div>
        <div style="font-size:11px;color:var(--color-text-secondary)">Erfolg</div>
      </div>
    </div>
    <div style="flex:1;min-width:200px">
      <div class="zk-metrics">
        <div class="zk-metric">
          <div class="zk-metric-val">${res.expectedZfp.toFixed(1)}</div>
          <div class="zk-metric-lbl">Erwartete ZfP*</div>
        </div>
        <div class="zk-metric">
          <div class="zk-metric-val" style="color:var(--color-text-success)">${(res.criticalRate*100).toFixed(2)}%</div>
          <div class="zk-metric-lbl">Kritischer Erfolg</div>
        </div>
        <div class="zk-metric">
          <div class="zk-metric-val" style="color:var(--color-text-danger)">${(res.fumbleRate*100).toFixed(2)}%</div>
          <div class="zk-metric-lbl">Patzer</div>
        </div>
      </div>
      <div style="margin-top:10px;font-size:12px;color:var(--color-text-secondary)">
        <span>Misslingen kostet <strong>${state.rep==="Hex"?"⅓":"½"}</strong> der geplanten AsP</span>
        ${state.rep==="Elf"?'<span style="margin-left:8px">· Wiederholung: <strong>+5</strong> statt +3</span>':''}
        ${res.successRate<0.1?`<span style="margin-left:8px;color:var(--color-text-danger)">Sehr schwierig!</span>`:''}
        ${res.successRate>0.95?`<span style="margin-left:8px;color:var(--color-text-success)">Nahezu sicher</span>`:''}
      </div>
    </div>
    <div style="flex:2;min-width:220px">
      <p style="font-size:12px;color:var(--color-text-secondary);margin-bottom:8px">ZfP*-Verteilung (bei Erfolg)</p>
      <div class="zk-dist">
        ${Object.entries(res.dist).sort((a,b)=>parseInt(a[0])-parseInt(b[0])).slice(0,Math.min(15,Object.keys(res.dist).length)).map(([k,v])=>{
          const pct=(v/8000*100);
          return `<div class="zk-dist-row">
            <span class="zk-dist-key">${k}</span>
            <div class="zk-dist-bar-wrap"><div class="zk-dist-bar" style="width:${Math.min(100,pct*4).toFixed(1)}%"></div></div>
            <span class="zk-dist-pct">${pct.toFixed(1)}%</span>
          </div>`;
        }).join("")}
        ${Object.keys(res.dist).length>15?`<div style="font-size:11px;color:var(--color-text-tertiary);margin-top:4px">… weitere ZfP*-Stufen nicht angezeigt</div>`:''}
      </div>
    </div>
  </div>
  ${state.spell&&state.spell[5]&&state.mods.MR===0?`<p class="zk-warn">Dieser Zauber richtet sich gegen die Magieresistenz des Opfers (+MR). Bitte MR-Wert eintragen!</p>`:''}
  `}
</div>
</div>`;

  app.innerHTML = html;
  const ddItems = app.querySelectorAll('.zk-dd-item');
  ddItems.forEach((el,i)=>{
    const s=filtered[i];
    if(s) el.addEventListener('mousedown',e=>{e.preventDefault();state.spell=s;state.search=s[0];state.showDD=false;render()});
  });
}

render();
</script>
